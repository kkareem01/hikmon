# Hikmon onboarding pipeline — environment variables
# Copy to .env for local `vercel dev`; set the real values in Vercel project settings.

# --- Stripe ---
# Secret key from https://dashboard.stripe.com/apikeys (use sk_test_... locally)
STRIPE_SECRET_KEY=sk_live_xxx

# --- Airtable ---
# Personal access token from https://airtable.com/create/tokens
# (scopes: data.records:read, data.records:write — on the onboarding base)
AIRTABLE_API_KEY=patxxx
AIRTABLE_BASE_ID=appxxx
AIRTABLE_TABLE_NAME=Clients
AIRTABLE_FAILED_TABLE_NAME=FailedSubmissions

# --- Resend ---
# API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxx
# Verified sending address (domain must be verified in Resend)
FROM_EMAIL=kareem@hikmon.net
# Where the internal new-client notification is sent
KAREEM_EMAIL=kareem@hikmon.net

# --- Cloudinary (used client-side; cloud name + preset are public, no secret) ---
CLOUDINARY_CLOUD_NAME=hikmon
CLOUDINARY_UPLOAD_PRESET=hikmon_onboarding_unsigned

# --- Site ---
# Public origin, used to build Stripe/Airtable deep links in emails
SITE_ORIGIN=https://www.hikmon.net
